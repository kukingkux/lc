{
    "comment": "An addon script that plays The Opened Way (Shadow of the Colossus) when you take the Apparatus. This script is designed to be used with the Default script. Bundled with PizzaProbability",
    "isAddon": true,
    "volumeGroups": [
        {
            "tag": "EscapeMusic",
            "volumeLerpSpeed": 2,
            "stoppingVolumeLerpSpeed": 0.25,
            "volumeRules": [
                {
                    "comment": "Spectator volume",
                    "volume": 0.5,
                    "condition": {
                        "conditionType": "Not",
                        "condition": {
                            "conditionType": "PlayerAlive"
                        }
                    }
                },
                {
                    "comment": "Inside facility volume",
                    "volume": 1,
                    "condition": {
                        "conditionType": "PlayerLocation",
                        "location": "Facility"
                    }
                },
                {
                    "comment": "Inside ship volume",
                    "volume": 0.4,
                    "condition": {
                        "conditionType": "PlayerLocation",
                        "location": "Ship"
                    }
                },
                {
                    "comment": "Default volume",
                    "volume": 0.7
                }
            ],
            "volumeModifiers": [
                {
                    "comment": "Crouching volume scale",
                    "volumeScale": 0.5,
                    "condition": {
                        "conditionType": "PlayerCrouching"
                    }
                }
            ]
        }
    ],
    "scriptEvents": [
        {
            "comment": "Stops the music if you take the Apparatus",
            "scriptEventType": "StopMusic",
            "gameEventType": "ApparatusTaken",
            "targetTags": [
                "EscapeMusic"
            ],
            "instant": true
        },
		{
            "comment": "The music that plays when you take the Apparatus",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "TheOpenedWayMeltdown.ogg"
            ]
        },
        {
            "comment": "Plays when you die after the Apparatus is taken",
            "scriptEventType": "PlayMusic",
            "gameEventType": "PlayerDied",
            "conditions": [
			    {
                    "conditionType": "Not",
                    "condition": {
					    "conditionType": "Or",
                        "conditions": [
                            {
                                "conditionType": "ApparatusDocked"
                            },
                            {
                                "conditionType": "ShipLeavingAlertCalled"
                            }
                        ]
					}
                }
            ],
            "overlapHandling": "overlap",
            "musicNames": [
                "YourFatAssSlowsYouDown.ogg"
            ]
        }
    ]
}
