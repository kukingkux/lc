{
    "comment": "An addon script that plays music when you take the Apparatus. Includes extra music from Pizza Tower. This script is designed to be used with the Default script. Bundled with PizzaProbability",
    "isAddon": true,
    "volumeGroups": [
        {
            "tag": "EscapeMusic",
            "volumeLerpSpeed": 2,
            "stoppingVolumeLerpSpeed": 0.25,
            "volumeRules": [
                {
                    "comment": "Spectator volume",
                    "volume": 0.5,
                    "condition": {
                        "conditionType": "Not",
                        "condition": {
                            "conditionType": "PlayerAlive"
                        }
                    }
                },
                {
                    "comment": "Inside facility volume",
                    "volume": 1,
                    "condition": {
                        "conditionType": "PlayerLocation",
                        "location": "Facility"
                    }
                },
                {
                    "comment": "Inside ship volume",
                    "volume": 0.4,
                    "condition": {
                        "conditionType": "PlayerLocation",
                        "location": "Ship"
                    }
                },
                {
                    "comment": "Default volume",
                    "volume": 0.7
                }
            ],
            "volumeModifiers": [
                {
                    "comment": "Crouching volume scale",
                    "volumeScale": 0.5,
                    "condition": {
                        "conditionType": "PlayerCrouching"
                    }
                }
            ]
        }
    ],
    "scriptEvents": [
        {
            "comment": "Stops the music if you take the Apparatus",
            "scriptEventType": "StopMusic",
            "gameEventType": "ApparatusTaken",
            "targetTags": [
                "EscapeMusic"
            ],
            "instant": true
        },
        {
            "comment": "The music that plays when you take the Apparatus on 5-Embrion",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [
                {
                    "conditionType": "CurrentMoon",
                    "moonName": "5 Embrion"
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "PizzaTimeNeverEndsMeltdown.ogg"
            ]
        },
        {
            "comment": "The music that plays during an eclipse when you take the Apparatus",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [
                {
                    "conditionType": "Weather",
                    "weather": "Eclipsed"
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "ThousandMarchMeltdown.ogg"
            ]
        },
		{
            "comment": "The music that plays during a storm when you take the Apparatus",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [
                {
                    "conditionType": "Weather",
                    "weather": "Stormy"
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "UnexpectancyMeltdown.ogg"
            ]
        },
        {
            "comment": "The music that plays when you take the Apparatus after 8PM",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [
                {
                    "conditionType": "And",
                    "conditions": [
                        {
                            "conditionType": "Weather",
                            "weather": "None"
                        },
                        {
                            "conditionType": "TimeOfDay",
                            "comparisonType": "GreaterThanOrEquals",
                            "time": 0.75
                        }
                    ]
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "ByeByeThereMeltdown.ogg"
            ]
        },
        {
            "comment": "The music that plays when you take the Apparatus after 4PM",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [
                {
                    "conditionType": "And",
                    "conditions": [
                        {
                            "conditionType": "Weather",
                            "weather": "None"
                        },
                        {
                            "conditionType": "TimeOfDay",
                            "comparisonType": "GreaterThanOrEquals",
                            "time": 0.5
                        }
                    ]
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "TheDeathThatIDeservioliMeltdown.ogg"
            ]
        },
		{
            "comment": "The music that plays when you take the Apparatus",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [
                {
                    "conditionType": "Weather",
                    "weather": "None"
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "ItsPizzaTimeMeltdown.ogg"
            ]
        },
		{
            "comment": "The music that plays during light weather when you take the Apparatus after 8PM",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [
                {
                    "conditionType": "TimeOfDay",
                    "comparisonType": "GreaterThanOrEquals",
                    "time": 0.75
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "INeedANoiseMeltdown.ogg"
            ]
        },
		{
            "comment": "The music that plays during light weather when you take the Apparatus after 4PM",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [
                {
                    "conditionType": "TimeOfDay",
                    "comparisonType": "GreaterThanOrEquals",
                    "time": 0.5
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "WorldWideNoiseMeltdown.ogg"
            ]
        },
		{
            "comment": "The music that plays during light weather when you take the Apparatus",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ApparatusTaken",
            "conditions": [],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "DistastefulAnchoviMeltdown.ogg"
            ]
        },
        {
            "comment": "Plays when you die after the Apparatus is taken",
            "scriptEventType": "PlayMusic",
            "gameEventType": "PlayerDied",
            "conditions": [
			    {
                    "conditionType": "Not",
                    "condition": {
					    "conditionType": "Or",
                        "conditions": [
                            {
                                "conditionType": "ApparatusDocked"
                            },
                            {
                                "conditionType": "ShipLeavingAlertCalled"
                            }
                        ]
					}
                }
            ],
            "overlapHandling": "overlap",
            "musicNames": [
                "YourFatAssSlowsYouDown.ogg"
            ]
        }
    ]
}
