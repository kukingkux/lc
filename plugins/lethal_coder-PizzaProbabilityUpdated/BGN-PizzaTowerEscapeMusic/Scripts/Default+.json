{
    "comment": "A replacement for the Default script that includes extra music from Pizza Tower. Bundled with PizzaProbability",
    "volumeGroups": [
        {
            "tag": "EscapeMusic",
            "volumeLerpSpeed": 2,
            "stoppingVolumeLerpSpeed": 0.25,
            "volumeRules": [
                {
                    "comment": "Spectator volume",
                    "volume": 0.5,
                    "condition": {
                        "conditionType": "Not",
                        "condition": {
                            "conditionType": "PlayerAlive"
                        }
                    }
                },
                {
                    "comment": "Inside facility volume",
                    "volume": 1,
                    "condition": {
                        "conditionType": "PlayerLocation",
                        "location": "Facility"
                    }
                },
                {
                    "comment": "Inside ship volume",
                    "volume": 0.4,
                    "condition": {
                        "conditionType": "PlayerLocation",
                        "location": "Ship"
                    }
                },
                {
                    "comment": "Default volume",
                    "volume": 0.7
                }
            ],
            "volumeModifiers": [
                {
                    "comment": "Crouching volume scale",
                    "volumeScale": 0.5,
                    "condition": {
                        "conditionType": "PlayerCrouching"
                    }
                }
            ]
        }
    ],
    "scriptEvents": [
        {
            "comment": "The music that plays when the early leave alert is called on 5-Embrion",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ShipLeavingAlertCalled",
            "conditions": [
                {
                    "conditionType": "CurrentMoon",
                    "moonName": "5 Embrion"
                }
            ],
            "overlapHandling": "IgnoreTag",
            "tag": "EscapeMusic",
            "musicNames": [
                "PizzaTimeNeverEnds.ogg"
            ]
        },
        {
            "comment": "The music that plays during an eclipse when the early leave alert is called",
            "scriptEventType": "PlayMusic",
            "gameEventType": "ShipLeavingAlertCalled",
            "conditions": [
                {
                    "conditionType": "Weather",
                    "weather": "Eclipsed"
